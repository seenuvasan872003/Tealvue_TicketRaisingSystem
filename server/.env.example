PORT=5000
MONGO_URI=mongodb://localhost:27017/tealvue_tickets
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Role limits
MAX_SUPER_ADMINS=2

# Email service (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_or_app_pass
EMAIL_FROM=Tealvue Support <your_email@gmail.com>

# File upload
MAX_FILE_SIZE_MB=5
MAX_FILES_PER_TICKET=30

# Notification Webhook Configuration
WEBHOOK_URL=http://localhost:5000/api/notifications/webhook-demo
